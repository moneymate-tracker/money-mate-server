              "raw": "{\n  \"type\": \"expense\",\n  \"categoryId\": \"{{categoryId}}\",\n  \"amount\": 45.50,\n  \"description\": \"Lunch at Chipotle\",\n  \"date\": \"2024-04-18\",\n  \"month\": 4,\n  \"year\": 2024\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/transactions", "host": ["{{baseUrl}}"], "path": ["api","v1","transactions"] }
          }
        },
        {
          "name": "Create Income Transaction",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
